# Copy to .env for local/cron runs. Do not commit real secrets.

# WordPress publishing
WP_BASE_URL=https://example.com
WP_USERNAME=publisher-bot
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_API_BASE_PATH=/wp-json/wp/v2
WP_DEFAULT_STATUS=draft

# Optional safety switches
# WP_REQUEST_SHAPE_ONLY=1
# WP_DRY_RUN_FORCE=1

# X publishing
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# R2 premium publishing
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PREMIUM_PREFIX=premium
