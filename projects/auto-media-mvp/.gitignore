# Runtime data
/node_modules/
/data/raw/**
/data/normalized/**
/data/candidates/**
/data/processed/**
/drafts/**
/output/**
/outputs/*
/logs/**

# State files
/state/*.json

# Keep directory structure
!/data/raw/.gitkeep
!/data/normalized/.gitkeep
!/data/candidates/.gitkeep
!/data/processed/.gitkeep
!/data/processed/requests/.gitkeep
!/data/processed/responses/.gitkeep
!/drafts/markdown/.gitkeep
!/drafts/note/.gitkeep
!/drafts/wordpress/.gitkeep
!/drafts/x/.gitkeep
!/output/daily/.gitkeep
!/output/weekly/.gitkeep
!/outputs/.gitkeep
!/outputs/note/
/outputs/note/*.md
!/outputs/note/.gitkeep
!/logs/.gitkeep

# Keep selected seed state examples only when explicitly added
!/state/.gitkeep
