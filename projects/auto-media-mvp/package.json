{
  "name": "auto-media-mvp",
  "private": true,
  "version": "0.1.0",
  "description": "MVP scaffold for automated media collection and draft generation",
  "dependencies": {
    "oauth-1.0a": "^2.2.6"
  },
  "scripts": {
    "test": "node --test tests/publish/lib_publish_adapters.test.js",
    "collect:techcrunch": "node scripts/collect/techcrunch_rss.js",
    "collect:hackernews": "node scripts/collect/hackernews_topstories.js",
    "collect:fed": "node scripts/collect/fed_press_releases.js",
    "collect:coingecko": "node scripts/collect/coingecko_markets.js",
    "collect:openai": "node scripts/collect/openai_announcements.js",
    "collect:anthropic": "node scripts/collect/anthropic_announcements.js",
    "collect:bls": "node scripts/collect/bls_releases.js",
    "rank:generate": "node scripts/rank/generate_rankings.js",
    "rank:render": "node scripts/rank/render_rankings_markdown.js",
    "rank:pages": "node scripts/rank/render_entity_pages.js",
    "premium:weekly-json": "node scripts/premium/build_weekly_json_snapshot.js",
    "premium:weekly-csv": "node scripts/premium/build_weekly_csv_pack.js",
    "premium:30-day-archive": "node scripts/premium/build_30_day_archive_pack.js",
    "premium:full-dataset": "node scripts/premium/build_full_ranking_dataset_pack.js",
    "premium:build": "npm run premium:weekly-json && npm run premium:weekly-csv",
    "premium:publish": "node scripts/premium/publish_premium_to_r2.js",
    "premium:test-link": "node scripts/premium/generate_test_download_url.js",
    "site:render": "node scripts/render_static_site.js",
    "site:build": "npm run rank:render && npm run rank:pages && npm run site:render && npm run premium:build",
    "site:serve": "python3 -m http.server 4173 --directory site",
    "run:observatory": "bash scripts/run_observatory_cycle.sh",
    "push:observatory": "bash scripts/push_observatory_updates.sh",
    "run:observatory:push": "npm run run:observatory && npm run push:observatory",
    "guard:prose-routes": "node scripts/guardrails/block_public_prose_routes.js",
    "generate:drafts": "npm run guard:prose-routes && node scripts/generate/normalize_to_draft.js",
    "generate:enrich": "npm run guard:prose-routes && node scripts/generate/enrich_from_sources.js",
    "title:build-requests": "npm run guard:prose-routes && node scripts/generate/build_title_requests.js",
    "title:worker": "npm run guard:prose-routes && node scripts/generate/run_title_worker.js",
    "title:apply": "npm run guard:prose-routes && node scripts/generate/apply_title_response.js",
    "test:worker:fallback": "node scripts/generate/test_worker_fallback.js",
    "xpost:build-requests": "npm run guard:prose-routes && node scripts/generate/build_xpost_requests.js",
    "xpost:worker": "npm run guard:prose-routes && node scripts/generate/run_xpost_worker.js",
    "xpost:apply": "npm run guard:prose-routes && node scripts/generate/apply_xpost_response.js",
    "article:build-requests": "npm run guard:prose-routes && node scripts/generate/build_article_requests.js",
    "article:worker": "npm run guard:prose-routes && node scripts/generate/run_article_worker.js",
    "article:apply": "npm run guard:prose-routes && node scripts/generate/apply_article_response.js",
    "image:build-requests": "npm run guard:prose-routes && node scripts/generate/build_image_prompt_requests.js",
    "image:worker": "npm run guard:prose-routes && node scripts/generate/run_image_prompt_worker.js",
    "image:apply": "npm run guard:prose-routes && node scripts/generate/apply_image_prompt_response.js",
    "publish:build-queue": "npm run guard:prose-routes && node scripts/publish/build_publish_queue.js",
    "publish:approve": "npm run guard:prose-routes && node scripts/publish/approve_publish_items.js",
    "publish:list-ready": "npm run guard:prose-routes && node scripts/publish/list_publish_ready.js",
    "publish:run": "npm run guard:prose-routes && node scripts/publish/run_publish_ready.js",
    "publish:check-fixture": "npm run guard:prose-routes && node scripts/publish/check_publish_fixture.js",
    "summary:enqueue": "npm run guard:prose-routes && node scripts/generate/enqueue_summary_requests.js",
    "summary:worker": "npm run guard:prose-routes && node scripts/generate/run_summary_worker.js",
    "summary:apply": "npm run guard:prose-routes && node scripts/generate/apply_summary_response.js",
    "generate:review-digest": "npm run guard:prose-routes && node scripts/generate/review_digest.js",
    "run:mvp": "bash scripts/run_mvp.sh"
  }
}
