# Cloudflare Pages Functions local example
DOWNLOAD_SIGNING_SECRET=replace-with-long-random-secret
GUMROAD_PRODUCT_ID_WEEKLY_JSON=replace-with-gumroad-product-id
GUMROAD_PRODUCT_ID_WEEKLY_CSV=replace-with-gumroad-product-id
