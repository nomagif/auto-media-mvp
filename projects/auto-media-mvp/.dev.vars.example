# Optional: override LLM worker executor command.
# Default is: node scripts/generate/openclaw_subagent_executor.js
# WORKER_EXECUTOR_CMD=node scripts/generate/openclaw_subagent_executor.js
# OPENCLAW_WORKER_TIMEOUT_SECONDS=180
